/**
 * ============================================================================
 * CeekayX Hospital Management System (HMS)
 * ============================================================================
 * Prisma Schema
 *
 * Database: MySQL
 *
 * This schema contains the security foundation of the application.
 *
 * Modules:
 *  - Users
 *  - Roles
 *  - Permissions
 *  - Refresh Tokens
 *  - Audit Logs
 *
 * Future modules:
 *  - Hospitals
 *  - Patients
 *  - Doctors
 *  - Pharmacy
 *  - Billing
 *  - Laboratory
 *  - Inventory
 *  - Appointments
 * ============================================================================
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////////////////////////////

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum PatientGender {
  male
  female
  other
}

enum PatientStatus {
  active
  inactive
  deceased
}

enum BedStatus {
  available
  occupied
  maintenance
  reserved
}

///////////////////////////////////////////////////////////////////////////////
// USER
///////////////////////////////////////////////////////////////////////////////

model User {
  /// Primary Key
  id String @id @default(uuid()) @db.Char(36)

  /// Login
  email    String @unique @db.VarChar(150)
  username String @unique @db.VarChar(100)

  passwordHash String @db.VarChar(255)

  /// Personal Information
  firstName String @db.VarChar(100)
  lastName  String @db.VarChar(100)

  phone String? @db.VarChar(30)

  /// Account Status
  isActive        Boolean @default(true)
  isEmailVerified Boolean @default(false)

  /// Security
  failedLoginAttempts Int @default(0)

  lockedUntil DateTime?

  lastLogin DateTime?

  passwordChangedAt DateTime?

  /// Offline Sync Version
  version Int @default(1)

  /// Audit Fields
  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  /// Relationships
  roles UserRole[]

  refreshTokens RefreshToken[]

  auditLogs AuditLog[]

  @@map("users")
}

///////////////////////////////////////////////////////////////////////////////
// PATIENT
///////////////////////////////////////////////////////////////////////////////

model Patient {
  id String @id @default(uuid()) @db.Char(36)

  mrn    String? @unique @db.VarChar(50)
  qrCode String? @unique @db.VarChar(120)

  firstName String @db.VarChar(100)
  lastName  String @db.VarChar(100)

  email String? @unique @db.VarChar(150)
  phone String? @unique @db.VarChar(30)

  dateOfBirth DateTime
  gender      PatientGender
  status      PatientStatus @default(active)

  address String? @db.VarChar(255)
  city    String? @db.VarChar(100)
  state   String? @db.VarChar(100)
  country String? @db.VarChar(100)

  emergencyContactName         String? @db.VarChar(150)
  emergencyContactPhone        String? @db.VarChar(30)
  emergencyContactRelationship String? @db.VarChar(80)

  bloodGroup String? @db.VarChar(10)
  genotype   String? @db.VarChar(10)
  allergies  String? @db.VarChar(500)

  insuranceProviderId String?            @db.Char(36)
  insuranceProvider   InsuranceProvider? @relation(fields: [insuranceProviderId], references: [id], onDelete: SetNull)
  insurancePolicyNumber String?          @db.VarChar(100)
  insuranceCoverageStatus String?        @db.VarChar(80)

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([insuranceProviderId])
  @@index([mrn])
  @@index([qrCode])
  @@index([status])
  @@map("patients")
}

model Department {
  id String @id @default(uuid()) @db.Char(36)

  name        String  @unique @db.VarChar(150)
  description String? @db.VarChar(500)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@map("departments")
}

model Specialty {
  id String @id @default(uuid()) @db.Char(36)

  name        String  @unique @db.VarChar(150)
  description String? @db.VarChar(500)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("specialties")
}

model Ward {
  id String @id @default(uuid()) @db.Char(36)

  name        String  @unique @db.VarChar(150)
  description String? @db.VarChar(500)
  isActive    Boolean @default(true)

  rooms Room[]
  beds  Bed[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("wards")
}

model Room {
  id String @id @default(uuid()) @db.Char(36)

  name        String  @db.VarChar(150)
  roomNumber  String  @unique @db.VarChar(50)
  roomType    String? @db.VarChar(100)
  description String? @db.VarChar(500)
  isActive    Boolean @default(true)

  wardId String? @db.Char(36)
  ward   Ward?   @relation(fields: [wardId], references: [id], onDelete: SetNull)

  beds Bed[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([wardId])
  @@map("rooms")
}

model Bed {
  id String @id @default(uuid()) @db.Char(36)

  bedNumber String    @unique @db.VarChar(50)
  status    BedStatus @default(available)
  isActive  Boolean   @default(true)

  wardId String? @db.Char(36)
  ward   Ward?   @relation(fields: [wardId], references: [id], onDelete: SetNull)

  roomId String? @db.Char(36)
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([wardId])
  @@index([roomId])
  @@map("beds")
}

model HospitalService {
  id String @id @default(uuid()) @db.Char(36)

  name        String  @unique @db.VarChar(150)
  code        String? @unique @db.VarChar(50)
  description String? @db.VarChar(500)
  price       Decimal @default(0) @db.Decimal(12, 2)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("hospital_services")
}

model InsuranceProvider {
  id String @id @default(uuid()) @db.Char(36)

  name        String  @unique @db.VarChar(150)
  code        String? @unique @db.VarChar(50)
  email       String? @db.VarChar(150)
  phone       String? @db.VarChar(30)
  address     String? @db.VarChar(255)
  description String? @db.VarChar(500)
  isActive    Boolean @default(true)

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("insurance_providers")
}

model HospitalProfile {
  id String @id @default(uuid()) @db.Char(36)

  name      String @db.VarChar(150)
  shortName String @db.VarChar(50)

  email String @db.VarChar(150)
  phone String @db.VarChar(30)

  address String @db.VarChar(255)
  city    String @db.VarChar(100)
  state   String @db.VarChar(100)
  country String @db.VarChar(100)

  logoUrl  String? @db.VarChar(500)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hospital_profiles")
}

///////////////////////////////////////////////////////////////////////////////
// ROLE
///////////////////////////////////////////////////////////////////////////////

model Role {
  id String @id @default(uuid()) @db.Char(36)

  name String @unique @db.VarChar(100)

  description String? @db.VarChar(255)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  permissions RolePermission[]

  users UserRole[]

  @@map("roles")
}

///////////////////////////////////////////////////////////////////////////////
// PERMISSION
///////////////////////////////////////////////////////////////////////////////

model Permission {
  id String @id @default(uuid()) @db.Char(36)

  name String @unique @db.VarChar(150)

  description String? @db.VarChar(255)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

///////////////////////////////////////////////////////////////////////////////
// USER ROLE (Many-to-Many)
///////////////////////////////////////////////////////////////////////////////

model UserRole {
  id String @id @default(uuid()) @db.Char(36)

  userId String @db.Char(36)

  roleId String @db.Char(36)

  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])

  @@index([userId])

  @@index([roleId])

  @@map("user_roles")
}

///////////////////////////////////////////////////////////////////////////////
// ROLE PERMISSION (Many-to-Many)
///////////////////////////////////////////////////////////////////////////////

model RolePermission {
  id String @id @default(uuid()) @db.Char(36)

  roleId String @db.Char(36)

  permissionId String @db.Char(36)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])

  @@index([roleId])

  @@index([permissionId])

  @@map("role_permissions")
}

///////////////////////////////////////////////////////////////////////////////
// REFRESH TOKENS
///////////////////////////////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(uuid()) @db.Char(36)

  token String @unique @db.VarChar(500)

  userId String @db.Char(36)

  expiresAt DateTime

  revoked Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@map("refresh_tokens")
}

///////////////////////////////////////////////////////////////////////////////
// AUDIT LOG
///////////////////////////////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid()) @db.Char(36)

  action AuditAction

  entity String @db.VarChar(100)

  entityId String? @db.Char(36)

  oldValues Json?

  newValues Json?

  ipAddress String? @db.VarChar(45)

  userAgent String? @db.VarChar(500)

  createdAt DateTime @default(now())

  userId String? @db.Char(36)

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])

  @@index([entity])

  @@index([action])

  @@map("audit_logs")
}
